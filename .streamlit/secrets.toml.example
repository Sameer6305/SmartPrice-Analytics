# Copy values from your PostgreSQL instance.
# For Streamlit Community Cloud, paste these into app Secrets.
# You can use either DATABASE_URL or DB_* fields.

# Option 1: Single connection string
DATABASE_URL = "postgresql://user:password@host:5432/smart_price_analytics"

# Option 2: Individual fields
DB_HOST = "your-db-host"
DB_PORT = 5432
DB_NAME = "smart_price_analytics"
DB_USER = "postgres"
DB_PASSWORD = "your-password"
